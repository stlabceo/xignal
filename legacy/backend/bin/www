#!/usr/bin/env node

/**
 * Module dependencies.
 */

var app = require('../app');
var debug = require('debug')('backend:server');
var http = require('http');
const seon = require('../seon');

const buildErrorPayload = (error) => ({
  name: error?.name || 'Error',
  message: error?.message || String(error || 'Unknown error'),
  stack: error?.stack || null,
});

const logRuntimeProcess = (stage, payload = {}) => {
  try {
    console.log(`[RUNTIME_PROCESS][${stage}] ${JSON.stringify({
      pid: process.pid,
      port: String(process.env.PORT || '3000'),
      runtimeOwnerPort: String(process.env.RUNTIME_OWNER_PORT || '3000'),
      ...payload,
    })}`);
  } catch (error) {
    console.log(`[RUNTIME_PROCESS][${stage}]`);
  }
};

process.on('unhandledRejection', (reason) => {
  console.error('[UNHANDLED_REJECTION]', reason);
  logRuntimeProcess('UNHANDLED_REJECTION', buildErrorPayload(reason));
});
process.on('uncaughtExceptionMonitor', (error, origin) => {
  logRuntimeProcess('UNCAUGHT_EXCEPTION_MONITOR', {
    origin: origin || null,
    ...buildErrorPayload(error),
  });
});
process.on('beforeExit', (code) => {
  logRuntimeProcess('BEFORE_EXIT', { code });
});
process.on('exit', (code) => {
  logRuntimeProcess('EXIT', { code });
});
process.on('SIGINT', () => {
  logRuntimeProcess('SIGINT');
});
process.on('SIGTERM', () => {
  logRuntimeProcess('SIGTERM');
});
const { createSocketServer } = require('../routes/socket');  // socket.js에서 가져오기

/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);
const runtimeOwnerPort = String(process.env.RUNTIME_OWNER_PORT || '3000');
const enableRuntime = String(port) === runtimeOwnerPort;

/**
 * Create HTTP server.
 */

var server = http.createServer(app);

/**
 * Setup Socket.io
 */

// const { io, users } = createSocketServer(server);
const {io, users} = require('../routes/socket')(server); // socket.js 실행

// const socket = require('../routes/socket')(server);
// socket.io = socket.io || require('socket.io')(server); // io 할당

/**
 * Listen on provided port, on all network interfaces.
 */
app.io = io;
app.users = users;

logRuntimeProcess('BOOTSTRAP', {
  enableRuntime,
});

seon.startRuntime({
  enabled: enableRuntime,
  ownerLabel: String(port),
}).catch((error) => {
  console.error(`[SEON_RUNTIME_START_ERROR] port:${port}`, error);
  logRuntimeProcess('RUNTIME_START_ERROR', buildErrorPayload(error));
});

server.listen(port, '0.0.0.0');
server.on('error', onError);
server.on('listening', onListening);
server.on('close', () => {
  logRuntimeProcess('SERVER_CLOSE');
});
server.on('clientError', (error, socket) => {
  logRuntimeProcess('SERVER_CLIENT_ERROR', buildErrorPayload(error));
  try {
    socket?.destroy?.();
  } catch (destroyError) {}
});


/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  logRuntimeProcess('SERVER_ERROR', {
    syscall: error?.syscall || null,
    code: error?.code || null,
    ...buildErrorPayload(error),
  });
  if (error.syscall !== 'listen') {
    throw error;
  }

  var bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  debug('Listening on ' + bind);
  logRuntimeProcess('SERVER_LISTENING', { bind });
}

