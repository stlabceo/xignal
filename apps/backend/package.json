{
  "name": "@xignal/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "node --import tsx --test \"src/**/*.spec.ts\"",
    "test:smoke": "node --import tsx --test \"src/**/*.integration-smoke.spec.ts\"",
    "stress:concurrency": "tsx scripts/concurrency-stress.ts",
    "stress:concurrency:same": "tsx scripts/concurrency-stress.ts --mode same-dedupe",
    "stress:concurrency:race": "tsx scripts/concurrency-stress.ts --mode resolve-race"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "express": "^4.21.2",
    "mysql2": "^3.14.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
